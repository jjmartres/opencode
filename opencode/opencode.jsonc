{
  "$schema": "https://opencode.ai/config.json",
  "model": "google-vertex/gemini-3.1-pro-preview",
  "small_model": "google-vertex/gemini-2.5-flash",
  "enabled_providers": ["google-vertex", "openrouter", "anthropic"],
  // "enabled_models": {
  //   "google-vertex": ["gemini-3*", "gemini-2*"],
  //   "openrouter": [
  //     "gpt-5.*-codex-*",
  //     "claude-sonnet-4-5*",
  //     "grok-code-fast*",
  //     "glm-4.7",
  //   ],
  // },
  "provider": {
    "google-vertex": {
      "models": {
        "gemini-2.5-flash": {
          "temperature": true,
        },
        "gemini-2.5-pro": {
          "temperature": true,
        },
        "gemini-3.1-pro-preview": {
          "temperature": true,
        },
      },
      "options": {
        "project": "{env:VERTEXAI_PROJECT_ID}",
        "location": "{env:VERTEXAI_REGION}",
      },
    },
    "anthropic": {
      "models": {
        "claude-opus-4-6": {
          "temperature": true,
        },
        "claude-sonnet-4-6": {
          "temperature": true,
        },
        "claude-haiku-4-5": {
          "temperature": true,
        },
      },
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}",
      },
    },
  },
  "default_agent": "plan",
  "autoupdate": true,
  "instructions": ["rules/*.md"],
  // WARNING: this is a security risk, do not share sessions with anyone automatically.
  "share": "manual",
  "plugin": ["@franlol/opencode-md-table-formatter"],
  "mcp": {
    "smartplaylist": {
      "type": "remote",
      "url": "http://personal.local:8000/mcp",
      "enabled": true,
    },
  },
}
