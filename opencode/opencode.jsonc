{
  "$schema": "https://opencode.ai/config.json",
  "model": "google-vertex/gemini-3.1-pro-preview",
  "small_model": "google-vertex/gemini-2.5-flash",
  "enabled_providers": ["google-vertex", "openrouter", "anthropic", "omlx"],
  "provider": {
    "google-vertex": {
      "models": {
        "gemini-2.5-flash": {
          "temperature": true,
        },
        "gemini-2.5-pro": {
          "temperature": true,
        },
        "gemini-3.1-pro-preview": {
          "temperature": true,
        },
      },
      "options": {
        "project": "{env:VERTEXAI_PROJECT_ID}",
        "location": "{env:VERTEXAI_REGION}",
      },
    },
    "anthropic": {
      "models": {
        "claude-opus-4-6": {
          "temperature": true,
        },
        "claude-sonnet-4-6": {
          "temperature": true,
        },
        "claude-haiku-4-5": {
          "temperature": true,
        },
      },
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}",
      },
    },
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "{env:OMLX_API_KEY}",
      },
      "models": {
        "gemma-4-26b-a4b-it-4bit": {
          "name": "gemma-4-26b-a4b-it-4bit",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
          "attachment": true,
          "limit": {
            "context": 32768,
            "output": 32768,
          },
        },
        "Qwen3-Coder-30B-A3B-Instruct-MLX-4bit": {
          "name": "Qwen3-Coder-30B-A3B-Instruct-MLX-4bit",
          "modalities": {
            "input": ["text"],
            "output": ["text"],
          },
          "limit": {
            "context": 32768,
            "output": 32768,
          },
        },
      },
    },
  },
  "default_agent": "plan",
  "autoupdate": true,
  "instructions": ["rules/*.md"],
  "share": "disabled",
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-websearch-cited@1.2.0",
    "@mohak34/opencode-notifier@latest",
  ],
  "mcp": {
    "smartplaylist": {
      "type": "remote",
      "url": "http://personal.local:8000/mcp",
      "enabled": true,
    },
  },
}
