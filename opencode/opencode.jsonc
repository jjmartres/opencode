{
  "$schema": "https://opencode.ai/config.json",
  "model": "google-vertex/gemini-3-pro-preview",
  "small_model": "openrouter/gpt-5-1-codex-mini",
  "enabled_providers": ["google-vertex", "openrouter"],
  // "enabled_models": {
  //   "google-vertex": ["gemini-3*", "gemini-2*"],
  //   "openrouter": [
  //     "gpt-5.*-codex-*",
  //     "claude-sonnet-4-5*",
  //     "grok-code-fast*",
  //     "glm-4.7",
  //   ],
  // },
  "provider": {
    "google-vertex": {
      "models": {
        "gemini-2.5-flash": {
          "temperature": true,
        },
        "gemini-2.5-pro": {
          "temperature": true,
        },
        "gemini-3-pro-preview": {
          "temperature": true,
        },
      },
      "options": {
        "project": "{env:VERTEXAI_PROJECT_ID}",
        "location": "{env:VERTEXAI_REGION}",
      },
    },
  },
  "default_agent": "plan",
  "autoupdate": true,
  "instructions": ["rules/*.md"],
  // WARNING: this is a security risk, do not share sessions with anyone automatically.
  "share": "manual",
  "plugin": ["@franlol/opencode-md-table-formatter"],
  "mcp": {
    "docker": {
      "type": "local",
      "command": ["uvx", "docker-mcp"],
      "enabled": false,
    },
    "smartplaylist": {
      "type": "remote",
      "url": "http://personal.local:8000/mcp",
      "enabled": true,
    },
  },
}
